{
  "name": "vibe-clinic-workspace",
  "private": true,
  "version": "2.0.1",
  "description": "Vibe Clinic backend and frontend workspace",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "test": "npm run backend:test",
    "test:self": "npm --prefix backend run test:self",
    "test:example": "npm --prefix backend run test:example",
    "dashboard:example": "node --env-file=.env backend/bin/vibe-clinic.js dashboard --cwd examples/calculator --port 7700",
    "sync:rules": "node backend/bin/sync-rules.js",
    "sync:rules:global": "node backend/bin/sync-rules.js --global",
    "backend:test": "npm --prefix backend run test",
    "backend:serve": "npm --prefix backend run serve",
    "backend:mcp": "npm --prefix backend run mcp",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:lint": "npm --prefix frontend run lint",
    "frontend:v1:dev": "npm --prefix frontend/legacy-v1/dashboard-ui run dev",
    "frontend:v1:build": "npm --prefix frontend/legacy-v1/dashboard-ui run build",
    "frontend:v1:lint": "npm --prefix frontend/legacy-v1/dashboard-ui run lint",
    "dashboard:v1": "npm --prefix backend run dashboard:v1",
    "dashboard:v2": "npm --prefix backend run dashboard:v2",
    "dashboard:example:v2": "node --env-file=.env backend/bin/vibe-clinic.js dashboard --cwd examples/calculator --port 7700 --ui v2",
    "publish": "echo 'Error: Public publishing is strictly prohibited.' && exit 1"
  }
}