{
  "name": "vibe-diagnosis-vscode",
  "displayName": "Vibe Diagnosis",
  "description": "Self-diagnosis framework for vibe coding projects — Health monitoring, diagnostics dashboard, and error pattern tracking for AI-assisted development",
  "version": "1.1.0",
  "publisher": "gyeoms-vibe",
  "license": "Apache-2.0",
  "contributors": [
    "Rejard <lemaiiisk@gmail.com>"
  ],
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "vibe-coding",
    "diagnosis",
    "testing",
    "ai",
    "self-diagnosis",
    "health-check",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gyeoms-vibe/260709_vibe-diagnosis"
  },
  "homepage": "https://github.com/gyeoms-vibe/260709_vibe-diagnosis#readme",
  "bugs": {
    "url": "https://github.com/gyeoms-vibe/260709_vibe-diagnosis/issues"
  },
  "main": "./src/extension.js",
  "activationEvents": [
    "workspaceContains:.vibe-diagnosis"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vibeDiagnosis.run",
        "title": "Vibe Diagnosis: Run"
      },
      {
        "command": "vibeDiagnosis.init",
        "title": "Vibe Diagnosis: Init"
      },
      {
        "command": "vibeDiagnosis.runJson",
        "title": "Vibe Diagnosis: Run (JSON)"
      },
      {
        "command": "vibeDiagnosis.dashboard",
        "title": "Vibe Diagnosis: Open Dashboard"
      },
      {
        "command": "vibeDiagnosis.repair",
        "title": "Vibe Diagnosis: Auto Repair"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
